# 树莓派模拟器配置

# 服务端地址
RASPBERRY_SERVER_BASE_URL=http://localhost:8080

# 登录凭据 
RASPBERRY_USERNAME=admin
RASPBERRY_PASSWORD=123456

# 时间间隔配置（秒）
RASPBERRY_STATUS_INTERVAL_SECONDS=5
RASPBERRY_MIN_POLL_INTERVAL_SECONDS=1
RASPBERRY_MAX_POLL_INTERVAL_SECONDS=2
RASPBERRY_MIN_DETECTION_INTERVAL_SECONDS=30
RASPBERRY_MAX_DETECTION_INTERVAL_SECONDS=60

# 起始 GPS 坐标
RASPBERRY_START_LONGITUDE=113.234567
RASPBERRY_START_LATITUDE=23.123456
